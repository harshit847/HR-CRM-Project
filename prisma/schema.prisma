generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BlueprintRun {
  id           String   @id @default(cuid())
  prompt       String
  appName      String
  blueprint    String
  validation   String
  repairs      String
  metrics      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
